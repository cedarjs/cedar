{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/cjs",
    "tsBuildInfoFile": "./tsconfig.types-cjs.tsbuildinfo",
    "verbatimModuleSyntax": false
  },
  "exclude": [
    "dist",
    "node_modules",
    "**/__mocks__",
    "**/__tests__", // dont build types for tests
    "**/__typetests__"
  ]
}
