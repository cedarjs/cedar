{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  // Tests are intentionally included here (not excluded like the build base) so the
  // IDE type-checks test files too. During actual builds, tsconfig.build.json adds
  // **/__tests__ back to the exclude.
  "references": [
    { "path": "../project-config" },
    { "path": "../framework-tools" }
  ]
}
