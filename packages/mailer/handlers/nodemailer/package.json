    "build:watch": "nodemon --watch src --ext \"js,jsx,ts,tsx\" --ignore dist --exec \"yarn build\"",
    "prepublishOnly": "NODE_ENV=production yarn build"
  },
  "dependencies": {
    "@cedarjs/mailer-core": "5.0.2",
    "nodemailer": "8.0.4"
  },
  "devDependencies": {
    "@cedarjs/framework-tools": "5.0.2",
    "@types/nodemailer": "^6",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
