{
  "name": "@cedarjs/vite",
  "version": "4.2.0",
  "description": "Vite configuration package for CedarJS",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cedarjs/cedar.git",
    "directory": "packages/vite"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./api": {
      "types": "./dist/api/vite-plugin-cedar-vitest-api-preset.d.ts",
      "default": "./dist/api/vite-plugin-cedar-vitest-api-preset.js"
    },
    "./client": {
      "require": "./dist/cjs/client.js",
      "import": "./dist/client.js"
    },
    "./buildFeServer": {
      "require": "./dist/cjs/buildFeServer.js",
      "import": "./dist/buildFeServer.js"
    },
    "./buildUDApiServer": {
      "import": "./dist/buildUDApiServer.js"
    },
    "./build": {
      "import": "./dist/build/build.js",
      "default": "./dist/cjs/build/build.js"
    },
    "./bins/cedar-vite-build.mjs": "./bins/cedar-vite-build.mjs",
    "./ud-handlers/graphql": {
      "import": {
        "types": "./dist/ud-handlers/graphql.d.ts",
        "default": "./dist/ud-handlers/graphql.js"
      },
      "require": {
        "types": "./dist/cjs/ud-handlers/graphql.d.ts",
        "default": "./dist/cjs/ud-handlers/graphql.js"
      }
    },
    "./ud-handlers/function": {
      "import": {
        "types": "./dist/ud-handlers/function.d.ts",
        "default": "./dist/ud-handlers/function.js"
      },
      "require": {
        "types": "./dist/cjs/ud-handlers/function.d.ts",
        "default": "./dist/cjs/ud-handlers/function.js"
      }
    },
    "./ud-handlers/catch-all": {
      "import": {
        "types": "./dist/ud-handlers/catch-all.d.ts",
        "default": "./dist/ud-handlers/catch-all.js"
      },
      "require": {
        "types": "./dist/cjs/ud-handlers/catch-all.d.ts",
        "default": "./dist/cjs/ud-handlers/catch-all.js"
      }
    }
  },
  "bin": {
    "cedar-dev-fe": "./dist/devFeServer.js",
    "cedar-serve-fe": "./dist/runFeServer.js",
    "cedar-unified-dev": "./dist/cedar-unified-dev.js",
    "cedar-vite-build": "./bins/cedar-vite-build.mjs",
    "cedar-vite-dev": "./bins/cedar-vite-dev.mjs",
    "vite": "./bins/vite.mjs"
  },
  "files": [
    "dist",
    "bins",
    "inject"
  ],
  "scripts": {
    "build": "tsx build.ts && yarn build:types",
    "build:pack": "yarn pack -o cedarjs-vite.tgz",
    "build:types": "tsc --build --verbose ./tsconfig.build.json",
    "check:attw": "tsx ./attw.ts",
    "check:package": "concurrently npm:check:attw yarn:publint",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@ast-grep/napi": "0.42.1",
    "@babel/generator": "7.29.1",
    "@babel/parser": "7.29.3",
    "@babel/traverse": "7.29.0",
    "@cedarjs/api": "workspace:*",
    "@cedarjs/api-server": "workspace:*",
    "@cedarjs/auth": "workspace:*",
    "@cedarjs/babel-config": "workspace:*",
    "@cedarjs/context": "workspace:*",
    "@cedarjs/cookie-jar": "workspace:*",
    "@cedarjs/graphql-server": "workspace:*",
    "@cedarjs/internal": "workspace:*",
    "@cedarjs/project-config": "workspace:*",
    "@cedarjs/server-store": "workspace:*",
    "@cedarjs/testing": "workspace:*",
    "@cedarjs/web": "workspace:*",
    "@fastify/url-data": "6.0.3",
    "@swc/core": "1.15.33",
    "@universal-deploy/node": "^0.1.6",
    "@universal-deploy/store": "^0.2.1",
    "@universal-deploy/vite": "^0.1.9",
    "@vitejs/plugin-react": "4.7.0",
    "@whatwg-node/fetch": "0.10.13",
    "@whatwg-node/server": "0.10.18",
    "acorn": "8.16.0",
    "acorn-loose": "8.5.2",
    "ansis": "4.2.0",
    "buffer": "6.0.3",
    "busboy": "^1.6.0",
    "cookie": "1.1.1",
    "dotenv-defaults": "5.0.2",
    "execa": "5.1.1",
    "express": "4.22.1",
    "fastify": "5.8.5",
    "fastify-raw-body": "5.0.0",
    "find-my-way": "8.2.2",
    "http-proxy-middleware": "3.0.5",
    "isbot": "5.1.40",
    "react": "19.2.3",
    "react-server-dom-webpack": "19.2.4",
    "rimraf": "6.1.3",
    "rou3": "^0.8.1",
    "vite": "7.3.2",
    "vite-plugin-cjs-interop": "2.4.4",
    "vite-plugin-node-polyfills": "0.26.0",
    "ws": "8.20.0",
    "yargs-parser": "21.1.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@hyrious/esbuild-plugin-commonjs": "0.2.6",
    "@types/aws-lambda": "8.10.161",
    "@types/busboy": "^1",
    "@types/express": "4",
    "@types/react": "^18.2.55",
    "@types/ws": "^8",
    "@types/yargs-parser": "21.0.3",
    "concurrently": "9.2.1",
    "glob": "11.1.0",
    "memfs": "4.57.2",
    "publint": "0.3.20",
    "rollup": "4.60.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "3905ed045508b861b495f8d5630d76c7a157d8f1"
}
