{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".github/actions/**",
    ".github/scripts/**",
    "__fixtures__/**",
    "docs/**",
    "local-testing-project/**",
    "local-testing-project-live/**",
    "packages/**/__fixtures__/**",
    "packages/**/__testfixtures__/**",
    "packages/**/dist/**",
    "packages/**/fixtures/**",
    "packages/create-cedar-app/templates/**"
  ],
  "exclude": ["files", "exports", "types", "enumMembers", "duplicates"],
  "ignoreBinaries": [
    "cedar",
    "code",
    "create-cedar-app",
    "cygpath",
    "k6",
    "powershell",
    "redwood",
    "rw"
  ],
  "ignoreUnresolved": ["/@react-refresh", "~__CEDAR__USER_ROUTES_FOR_MOCK"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
