{
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node16",
    "baseUrl": "./",
    "rootDirs": [
      "./src",
      "../.cedar/types/mirror/api/src"
    ],
    "paths": {
      "src/*": [
        "./src/*",
        "../.cedar/types/mirror/api/src/*"
      ],
      "types/*": ["./types/*", "../types/*"],
      "@cedarjs/testing": ["../node_modules/@cedarjs/testing/api"]
    },
    "typeRoots": [
      "../node_modules/@types",
      "./node_modules/@types"
    ],
    "types": ["jest"],
  },
  "include": [
    "src",
    "../.cedar/types/includes/all-*",
    "../.cedar/types/includes/api-*",
    "../types"
  ]
}
